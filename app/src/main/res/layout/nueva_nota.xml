<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tv_contrasena_individual"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:text="@string/contrasena_individual"
        android:textColor="@color/texto_principal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_comentario"
        app:layout_constraintVertical_bias="0.03" />

    <EditText
        android:id="@+id/et_contrasena_individual"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_contrasena_individual"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tv_nueva_contrasena"
        android:layout_width="330dp"
        android:layout_height="47dp"
        android:text="@string/nueva_nota"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textSize="30sp"
        android:textColor="@color/texto_principal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.05" />

    <EditText
        android:id="@+id/et_titulo"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_titulo"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tv_titulo"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:text="@string/titulo"
        android:textColor="@color/texto_principal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_nueva_contrasena"
        app:layout_constraintVertical_bias="0.05" />

    <TextView
        android:id="@+id/tv_comentario"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:text="@string/comentario"
        android:textColor="@color/texto_principal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_usuario"
        app:layout_constraintVertical_bias="0.03" />

    <EditText
        android:id="@+id/et_comentario"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_comentario"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tv_nota"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:text="@string/nota"
        android:textColor="@color/texto_principal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_titulo"
        app:layout_constraintVertical_bias="0.03" />

    <EditText
        android:id="@+id/et_usuario"
        android:layout_width="330dp"
        android:layout_height="40dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_nota"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/btn_crear"
        android:layout_width="150dp"
        android:layout_height="65dp"
        android:backgroundTint="@color/acento_celeste"
        android:text="@string/crear"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:textSize="17sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.157"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.902" />

    <Button
        android:id="@+id/btn_cancelar"
        android:layout_width="150dp"
        android:layout_height="65dp"
        android:backgroundTint="@color/red"
        android:text="@string/cancelar"
        android:textStyle="bold"
        android:textColor="@color/texto_principal"
        android:textSize="17sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.846"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.902" />

</androidx.constraintlayout.widget.ConstraintLayout>